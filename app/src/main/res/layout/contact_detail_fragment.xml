<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/grey">


    <ImageView
        android:id="@+id/imageView"
        android:layout_width="120dp"
        android:layout_height="100dp"
        android:layout_margin="10dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:src = "@drawable/contact"
        android:contentDescription="@string/contact_picture" />

    <TextView
        android:id="@+id/detailTextViewName"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="6dp"
        android:background="@color/dark_grey"
        android:fontFamily="sans-serif-medium"
        android:gravity="center_vertical"
        android:paddingStart="10dp"
        android:text="@string/contact_name"
        android:textColor="@color/white"
        android:textSize="28sp"
        app:layout_constraintBottom_toBottomOf="@+id/imageView"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/imageView"
        app:layout_constraintTop_toTopOf="@+id/imageView"
        tools:ignore="RtlSymmetry" />

    <TextView
        android:id="@+id/detailTextViewNumber"
        android:layout_width="0dp"
        android:fontFamily="sans-serif-medium"
        android:background="@color/dark_grey"
        android:layout_height="wrap_content"
        android:text="@string/phone_number"
        android:textColor="@color/white"
        android:paddingStart="10dp"
        tools:ignore="RtlSymmetry"
        android:textSize="18sp"
        android:layout_margin="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/imageView"
         />

    <TextView
        android:id="@+id/detailTextViewNumber2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/phone_number_2"
        android:textSize="18sp"
        android:fontFamily="sans-serif-medium"
        android:background="@color/dark_grey"
        android:textColor="@color/white"
        android:paddingStart="10dp"
        tools:ignore="RtlSymmetry"
        android:layout_margin="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/detailTextViewNumber" />

    <TextView
        android:id="@+id/detailTextView1"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/dark_grey"
        android:text="..."
        android:textSize="18sp"
        android:fontFamily="sans-serif-medium"
        android:textColor="@color/white"
        android:textAlignment="center"
        android:layout_margin="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/detailTextViewNumber2" />

    <TextView
        android:id="@+id/detailTextViewEmail"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/mail_1"
        android:textSize="18sp"
        android:background="@color/dark_grey"
        android:fontFamily="sans-serif-medium"
        android:textColor="@color/white"
        android:paddingStart="10dp"
        tools:ignore="RtlSymmetry"
        android:layout_margin="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/detailTextView1" />

    <TextView
        android:id="@+id/detailTextViewEmail2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/mail_2"
        android:textColor="@color/white"
        android:paddingStart="10dp"
        android:background="@color/dark_grey"
        android:textSize="18sp"
        android:fontFamily="sans-serif-medium"
        tools:ignore="RtlSymmetry"
        android:layout_margin="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/detailTextViewEmail" />

    <TextView
        android:id="@+id/detailTextView2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="..."
        android:textColor="@color/white"
        android:textAlignment="center"
        android:background="@color/dark_grey"
        android:fontFamily="sans-serif-medium"
        android:textSize="18sp"
        android:layout_margin="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/detailTextViewEmail2" />

    <TextView
        android:id="@+id/detailTextViewDescription"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="12dp"
        android:paddingStart="10dp"
        android:fontFamily="sans-serif-medium"
        android:background="@color/dark_grey"
        android:text="@string/description"
        android:gravity="center_vertical"
        android:textColor="@color/white"
        android:textSize="18sp"
        app:layout_constraintBottom_toTopOf="@+id/guideline"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/detailTextView2" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_begin="470dp" />

</androidx.constraintlayout.widget.ConstraintLayout>